{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/proxy" },
    { "source": "/", "destination": "/web/login.html" },
    { "source": "/dashboard", "destination": "/web/dashboard.html" },
    { "source": "/login", "destination": "/web/login.html" },
    { "source": "/:path((?!api/).*)", "destination": "/web/:path" }
  ]
}
